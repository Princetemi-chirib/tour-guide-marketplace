{
  "name": "tour-guide-marketplace",
  "private": true,
  "engines": {
    "node": ">=20 <23"
  },
  "workspaces": [
    "fe",
    "be"
  ],
  "scripts": {
    "dev": "concurrently -k -n fe,be -c cyan,magenta \"npm run dev -w fe\" \"npm run dev -w be\"",
    "dev:fe": "npm run dev -w fe",
    "dev:be": "npm run dev -w be",
    "build": "npm run build -w fe",
    "start:be": "npm run start -w be"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
